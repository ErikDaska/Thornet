data/raw/
data/processed/
data/latest_predictions.csv
*.nc
*.tar.gz
*.zip
*.h5
*.hdf5

# ── MLflow ────────────────────────────────────────────────────
mlruns/
mlflow.db
*.db

# ── DVC ───────────────────────────────────────────────────────
/emi_remote/
.dvc/tmp/
.dvc/cache/

# ── Outputs & Artefactos ──────────────────────────────────────
outputs/
logs/
*.log
*.png
*.jpg
*.jpeg
*.gif

# ── Airflow ───────────────────────────────────────────────────
airflow.cfg
airflow.db
airflow-webserver.pid
standalone_admin_password.txt
dags/__pycache__/

